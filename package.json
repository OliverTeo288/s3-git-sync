{
  "name": "s3-git-sync",
  "version": "1.0.2",
  "description": "Obsidian plugin: sync vault to S3 with a git-like workflow",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "clean": "rimraf main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:docker": "bash scripts/test-docker.sh"
  },
  "keywords": [],
  "author": "OliverTeo288",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "obsidian": "^1.5.7",
    "rimraf": "^6.0.1",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/credential-providers": "^3.1039.0",
    "@aws-sdk/lib-storage": "^3.1039.0",
    "@smithy/fetch-http-handler": "^5.3.17",
    "@smithy/protocol-http": "^5.3.14",
    "@smithy/querystring-builder": "^4.2.14",
    "localforage": "^1.10.0",
    "nanoid": "^5.0.7"
  }
}
